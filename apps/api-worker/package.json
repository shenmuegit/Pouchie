{
  "name": "@xiaohebao/api-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts --port 8787",
    "deploy": "wrangler deploy src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply xiaohebao-dev --local",
    "db:seed:local": "wrangler d1 execute xiaohebao-dev --local --file=./migrations/0002_seed.sql"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "@xiaohebao/contracts": "0.1.0",
    "@xiaohebao/domain": "0.1.0",
    "hono": "^4.7.5",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260330.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8",
    "wrangler": "^4.10.0"
  }
}
