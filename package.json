{
  "name": "xiaohebao-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm run dev --workspace @xiaohebao/mobile",
    "dev:api": "npm run dev --workspace @xiaohebao/api-worker",
    "build": "npm run -ws build --if-present",
    "typecheck": "npm run -ws typecheck --if-present",
    "test": "npm run -ws test --if-present"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "overrides": {
    "wrangler": {
      "esbuild": "0.24.2"
    }
  },
  "packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c"
}
